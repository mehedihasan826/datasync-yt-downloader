SERVER_PORT=8765

# Optional: Telegram Bot configuration
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
TELEGRAM_ALLOWED_USER_IDS=your_telegram_user_id
TELEGRAM_POLLING_ENABLED=true
TELEGRAM_STATUS_UPDATE_MODE=edit_message

YTDLP_EMBED_METADATA=true
YTDLP_EMBED_THUMBNAIL=true
KEEP_INFO_JSON=true

YTDLP_ARCHIVE_FILE=

WORK_DIR=/Users/yourname/Music/DataSyncYTDownloaderWork
MUSIC_IMPORT_DIR=/Users/yourname/Music/Music/Media/Automatically Add to Music.localized

MAX_PLAYLIST_ITEMS=50
DUPLICATE_SKIP=true
IMPORT_MODE=AUTO_FOLDER

AUTO_CLEAN_IMPORTED_AFTER_MASTER_IMPORT=true
KEEP_IMPORTED_BACKUP_DAYS=0

YTDLP_BINARY=yt-dlp
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe
